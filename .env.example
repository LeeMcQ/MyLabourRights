# ============================================================
# CaseGuide — Environment variables
# Set these in the NETLIFY DASHBOARD (Site settings > Environment
# variables). NEVER commit real keys to GitHub.
# Every variable is OPTIONAL — leave one out and that feature
# gracefully falls back (simulated AI / simulated payment).
# ============================================================

# --- AI (the smart-routing attorney) ---
# CaseGuide routes each question to the cheapest model that can handle it:
#   easy/medium questions -> Gemini Flash (FREE)
#   hard legal questions  -> Claude (capable, paid) — with auto-escalation
#     if a free-tier answer looks weak (cascade).
# This cuts AI cost 50-80% with minimal quality loss. Both keys optional:
#   - GEMINI only  -> everything runs on free Gemini (still good)
#   - CLAUDE only  -> everything runs on Claude
#   - BOTH         -> smart routing + cascade (recommended)
#   - NEITHER      -> built-in simulation (no cost, demo quality)

# Gemini is FREE — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude is PAID — get a key at https://console.anthropic.com
# Strongly recommended alongside Gemini so hard legal questions get the
# capable model while everyday chatter stays free.
CLAUDE_API_KEY=

# --- Payments (PayFast — South African gateway) ---
# Free merchant account at https://www.payfast.co.za
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
# 'sandbox' while testing, 'live' when ready to take real money
PAYFAST_MODE=sandbox

# --- Blog pipeline ---
# The email address AI drafts are sent to for your approval
APPROVAL_EMAIL=
# Free email-sending account at https://resend.com
RESEND_API_KEY=

# --- Social auto-posting (optional) ---
LINKEDIN_TOKEN=
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=

# Tender Intelligence module (DeepSeek = cheap tier, Claude = capable tier)
# Get a key at platform.deepseek.com — without keys the module runs its built-in simulation
DEEPSEEK_API_KEY=
